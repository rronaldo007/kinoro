{
  "name": "kinoro-app",
  "version": "0.0.1",
  "description": "Kinoro desktop editor — Electron shell.",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron . --no-sandbox",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.0"
  }
}
